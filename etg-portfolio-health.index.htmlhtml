// ─────────────────────────────────────────────────────────────────────────────
// TOOLTIP EVENT DELEGATION  (fixed-position, bypasses overflow clipping)
// ─────────────────────────────────────────────────────────────────────────────
document.addEventListener('mouseover', function(e) {
  const wrap = e.target.closest('.formula-wrap');
  if (!wrap) return;
  const tooltip = wrap.querySelector('.formula-tooltip');
  if (!tooltip) return;

  const rect = wrap.getBoundingClientRect();
  const spaceAbove = rect.top;
  const useAbove   = spaceAbove > 220;

  tooltip.classList.toggle('tt-above', useAbove);
  tooltip.classList.toggle('tt-below', !useAbove);

  // Horizontal centre, clamped to viewport edges
  const tipW    = parseInt(tooltip.style.width) || 260;
  let leftPx    = rect.left + rect.width / 2;
  leftPx        = Math.max(tipW / 2 + 8, Math.min(leftPx, window.innerWidth - tipW / 2 - 8));

  tooltip.style.left      = leftPx + 'px';
  tooltip.style.transform = 'translateX(-50%)';

  if (useAbove) {
    tooltip.style.top    = 'auto';
    tooltip.style.bottom = (window.innerHeight - rect.top + 10) + 'px';
  } else {
    tooltip.style.bottom = 'auto';
    tooltip.style.top    = (rect.bottom + 10) + 'px';
  }

  tooltip.style.display = 'block';
});

document.addEventListener('mouseout', function(e) {
  const wrap = e.target.closest('.formula-wrap');
  if (!wrap || wrap.contains(e.relatedTarget)) return;
  const tooltip = wrap.querySelector('.formula-tooltip');
  if (tooltip) tooltip.style.display = 'none';
});

// ─────────────────────────────────────────────────────────────────────────────
// INIT
// ─────────────────────────────────────────────────────────────────────────────
document.getElementById("refreshTs").textContent = "Last refreshed: " + new Date().toLocaleString();
filteredTools = [...TOOLS];
sortTools();
render();
</script>
</body>
