<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>ETG Portfolio Health Dashboard</title>
<style>
  :root {
    --green:  #16a34a; --green-bg:  #dcfce7; --green-border:  #86efac;
    --yellow: #ca8a04; --yellow-bg: #fef9c3; --yellow-border: #fde047;
    --red:    #dc2626; --red-bg:    #fee2e2; --red-border:    #fca5a5;
    --gray:   #6b7280; --gray-bg:   #f3f4f6; --gray-border:   #d1d5db;
    --blue:   #1d4ed8; --blue-bg:   #dbeafe;
    --font: 'Inter', system-ui, sans-serif;
    --surface: #ffffff; --bg: #f8fafc; --border: #e2e8f0;
    --text: #0f172a; --text-muted: #64748b;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: var(--font); background: var(--bg); color: var(--text); font-size: 14px; }

  .app-header {
    background: #0f172a; color: white; padding: 16px 32px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 3px solid #3b82f6;
  }
  .app-header h1 { font-size: 18px; font-weight: 700; letter-spacing: -.3px; }
  .app-header .sub { font-size: 12px; color: #94a3b8; margin-top: 2px; }
  .last-refresh { font-size: 11px; color: #64748b; background: #1e293b; padding: 4px 10px; border-radius: 6px; }

  .main { max-width: 1400px; margin: 0 auto; padding: 24px 32px; }

  /* ── Controls ── */
  .controls { display: flex; gap: 12px; align-items: center; margin-bottom: 20px; flex-wrap: wrap; }
  .controls label { font-size: 12px; font-weight: 600; color: var(--text-muted); margin-right: 4px; }
  select, input[type=text] {
    border: 1px solid var(--border); border-radius: 8px; padding: 8px 12px;
    font-size: 13px; background: var(--surface); color: var(--text); outline: none; transition: border .15s;
  }
  select:focus, input[type=text]:focus { border-color: #3b82f6; }
  .btn { padding: 8px 16px; border-radius: 8px; border: none; cursor: pointer; font-size: 13px; font-weight: 600; transition: opacity .15s; }
  .btn:hover { opacity: .85; }
  .btn-primary { background: #3b82f6; color: white; }
  .btn-ghost { background: var(--gray-bg); color: var(--text); border: 1px solid var(--border); }
  .spacer { flex: 1; }

  /* ── KPI Stats Bar ── */
  .kpi-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-bottom: 20px; }
  .kpi-card {
    background: var(--surface); border: 1px solid var(--border); border-radius: 14px;
    padding: 18px 22px;
  }
  .kpi-card .kc-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--text-muted); margin-bottom: 8px; }
  .kpi-card .kc-value { font-size: 28px; font-weight: 800; line-height: 1; }
  .kpi-card .kc-sub { font-size: 12px; color: var(--text-muted); margin-top: 5px; }
  .kpi-card .kc-sub.warn { color: var(--red); font-weight: 600; }
  .kpi-card .kc-sub.ok   { color: var(--green); font-weight: 600; }
  .kpi-card .kc-dots { display: flex; gap: 6px; align-items: center; margin-top: 6px; font-size: 11px; font-weight: 600; }
  .kpi-card .kc-dot { width: 7px; height: 7px; border-radius: 50%; }
  .renewal-row { display: flex; gap: 12px; margin-top: 6px; }
  .renewal-badge { font-size: 12px; font-weight: 700; padding: 3px 8px; border-radius: 6px; }

  /* ── Score Banner ── */
  .score-banner {
    background: var(--surface); border: 1px solid var(--border); border-radius: 16px;
    padding: 24px 32px; margin-bottom: 20px; display: flex; gap: 32px; align-items: center; flex-wrap: wrap;
  }
  .portfolio-score-block { text-align: center; }
  .portfolio-score-block .score-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .8px; color: var(--text-muted); }
  .portfolio-score-block .big-score { font-size: 56px; font-weight: 800; line-height: 1; margin: 4px 0; }
  .portfolio-score-block .score-grade { font-size: 13px; font-weight: 700; padding: 3px 12px; border-radius: 20px; display: inline-block; }
  .divider { width: 1px; background: var(--border); height: 80px; }
  .metric-pills { display: flex; gap: 16px; flex-wrap: wrap; flex: 1; }
  .metric-pill { flex: 1; min-width: 140px; border-radius: 12px; padding: 16px 20px; border: 1px solid var(--border); }
  .metric-pill .mp-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--text-muted); }
  .metric-pill .mp-score { font-size: 28px; font-weight: 800; margin: 4px 0; }
  .metric-pill .mp-name { font-size: 12px; color: var(--text-muted); }
  .metric-pill .mp-bar { height: 4px; border-radius: 2px; background: var(--gray-bg); margin-top: 8px; }
  .metric-pill .mp-bar-fill { height: 4px; border-radius: 2px; }

  /* ── Section ── */
  .section-title { font-size: 15px; font-weight: 700; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .section-title .count { font-size: 12px; font-weight: 500; color: var(--text-muted); background: var(--gray-bg); padding: 2px 8px; border-radius: 10px; }

  /* ── Owner Cards ── */
  .owner-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; margin-bottom: 24px; }
  .owner-card {
    background: var(--surface); border: 2px solid var(--border); border-radius: 12px;
    padding: 16px 18px; cursor: pointer; transition: all .15s; position: relative; overflow: hidden;
  }
  .owner-card:hover { border-color: #3b82f6; box-shadow: 0 4px 12px rgba(59,130,246,.12); transform: translateY(-1px); }
  .owner-card.active { border-color: #3b82f6; background: #eff6ff; }
  .owner-card .oc-name { font-weight: 700; font-size: 13px; margin-bottom: 8px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .owner-card .oc-score { font-size: 26px; font-weight: 800; }
  .owner-card .oc-meta { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
  .owner-card .oc-badge { position: absolute; top: 12px; right: 12px; font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; }

  /* ── Two-col insight row ── */
  .insight-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px; }
  @media (max-width: 900px) { .insight-row { grid-template-columns: 1fr; } }
  .panel { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
  .panel-header { padding: 14px 18px; border-bottom: 1px solid var(--border); font-size: 13px; font-weight: 700; display: flex; align-items: center; gap: 8px; }
  .panel-body { padding: 16px 18px; }

  /* ── Category Chart ── */
  .cat-row { display: flex; align-items: center; gap: 10px; margin-bottom: 10px; }
  .cat-name { font-size: 12px; font-weight: 600; width: 160px; flex-shrink: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .cat-bar-wrap { flex: 1; height: 20px; background: var(--gray-bg); border-radius: 4px; overflow: hidden; position: relative; }
  .cat-bar-fill { height: 100%; border-radius: 4px; display: flex; align-items: center; padding-left: 6px; transition: width .4s ease; }
  .cat-bar-label { font-size: 10px; font-weight: 700; color: white; white-space: nowrap; }
  .cat-meta { font-size: 11px; color: var(--text-muted); width: 60px; text-align: right; flex-shrink: 0; }
  .chart-legend { display: flex; gap: 14px; margin-bottom: 12px; flex-wrap: wrap; }
  .chart-legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; color: var(--text-muted); }
  .chart-legend-swatch { width: 10px; height: 10px; border-radius: 2px; }

  /* ── Overlap Panel ── */
  .overlap-card { border: 1px solid var(--border); border-radius: 10px; padding: 14px; margin-bottom: 10px; }
  .overlap-card:last-child { margin-bottom: 0; }
  .overlap-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 8px; }
  .overlap-cat { font-size: 13px; font-weight: 700; }
  .overlap-risk { font-size: 10px; font-weight: 700; padding: 2px 8px; border-radius: 10px; }
  .risk-high   { background: var(--red-bg);    color: var(--red); }
  .risk-medium { background: var(--yellow-bg); color: var(--yellow); }
  .risk-low    { background: var(--gray-bg);   color: var(--gray); }
  .overlap-tools { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 6px; }
  .overlap-tool-tag { font-size: 11px; padding: 2px 8px; background: var(--blue-bg); color: var(--blue); border-radius: 6px; font-weight: 600; }
  .overlap-note { font-size: 11px; color: var(--text-muted); }
  .overlap-cost { font-size: 12px; font-weight: 700; color: var(--red); margin-top: 4px; }

  /* ── Tool Table ── */
  .table-wrap { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; margin-bottom: 24px; }
  .table-header-row { padding: 16px 20px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  table { width: 100%; border-collapse: collapse; }
  thead tr { background: #f8fafc; }
  th { padding: 10px 14px; text-align: left; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--text-muted); border-bottom: 1px solid var(--border); white-space: nowrap; cursor: pointer; user-select: none; }
  th:hover { color: #3b82f6; }
  th .sort-icon { opacity: .4; margin-left: 4px; }
  td { padding: 11px 14px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #f8fafc; }
  .tool-name { font-weight: 600; font-size: 13px; }
  .tool-sub { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

  /* ── Score Chips & Bars ── */
  .chip { display: inline-flex; align-items: center; gap: 5px; padding: 4px 10px; border-radius: 20px; font-size: 12px; font-weight: 700; border: 1px solid transparent; }
  .chip-green  { background: var(--green-bg);  color: var(--green);  border-color: var(--green-border); }
  .chip-yellow { background: var(--yellow-bg); color: var(--yellow); border-color: var(--yellow-border); }
  .chip-red    { background: var(--red-bg);    color: var(--red);    border-color: var(--red-border); }
  .chip-gray   { background: var(--gray-bg);   color: var(--gray);   border-color: var(--gray-border); }
  .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0; }
  .score-bar-wrap { display: flex; align-items: center; gap: 8px; }
  .score-bar { height: 6px; width: 70px; border-radius: 3px; background: var(--gray-bg); overflow: hidden; flex-shrink: 0; }
  .score-bar-inner { height: 6px; border-radius: 3px; }
  .score-val { font-size: 12px; font-weight: 700; min-width: 28px; text-align: right; }

  /* ── Pagination ── */
  .pagination { display: flex; gap: 6px; align-items: center; justify-content: flex-end; padding: 12px 20px; border-top: 1px solid var(--border); }
  .page-btn { padding: 5px 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--surface); cursor: pointer; font-size: 12px; font-weight: 600; }
  .page-btn.active { background: #3b82f6; color: white; border-color: #3b82f6; }
  .page-btn:hover:not(.active) { border-color: #3b82f6; color: #3b82f6; }

  /* ── Legend ── */
  .legend { display: flex; gap: 16px; align-items: center; font-size: 12px; }
  .legend-item { display: flex; align-items: center; gap: 5px; color: var(--text-muted); }
  .legend-dot { width: 8px; height: 8px; border-radius: 50%; }

  /* ── Modal ── */
  .modal-backdrop { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 100; align-items: center; justify-content: center; }
  .modal-backdrop.open { display: flex; }
  .modal { background: var(--surface); border-radius: 16px; width: 640px; max-width: 95vw; max-height: 90vh; overflow-y: auto; box-shadow: 0 20px 60px rgba(0,0,0,.25); }
  .modal-header { padding: 20px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
  .modal-header h2 { font-size: 17px; font-weight: 700; }
  .modal-close { width: 30px; height: 30px; border-radius: 8px; border: 1px solid var(--border); background: none; cursor: pointer; font-size: 16px; display: flex; align-items: center; justify-content: center; }
  .modal-body { padding: 24px; }
  .modal-section { margin-bottom: 20px; }
  .modal-section h3 { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: var(--text-muted); margin-bottom: 10px; }
  .score-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .score-card { border: 1px solid var(--border); border-radius: 10px; padding: 14px; }
  .score-card .sc-label { font-size: 11px; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: .5px; }
  .score-card .sc-val { font-size: 28px; font-weight: 800; margin: 4px 0 2px; }
  .score-card .sc-desc { font-size: 11px; color: var(--text-muted); }
  .kv-row { display: flex; justify-content: space-between; padding: 7px 0; border-bottom: 1px solid #f1f5f9; font-size: 13px; }
  .kv-row:last-child { border-bottom: none; }
  .kv-key { color: var(--text-muted); }
  .kv-val { font-weight: 600; }
  .flag-list { display: flex; flex-direction: column; gap: 6px; }
  .flag { padding: 8px 12px; border-radius: 8px; font-size: 12px; font-weight: 600; }
  .flag-red    { background: var(--red-bg);    color: var(--red); }
  .flag-yellow { background: var(--yellow-bg); color: var(--yellow); }
  .flag-green  { background: var(--green-bg);  color: var(--green); }

  /* ── KPI Field Tags ── */
  .kpi-tag { display: inline-flex; align-items: center; padding: 1px 6px; border-radius: 4px; font-size: 10px; font-weight: 700; margin-left: 6px; vertical-align: middle; white-space: nowrap; }
  .kt-adoption     { background: #cffafe; color: #0e7490; }
  .kt-spend        { background: #ede9fe; color: #6d28d9; }
  .kt-contract     { background: #ffedd5; color: #c2410c; }
  .kt-completeness { background: #dbeafe; color: #1d4ed8; }
  .kpi-legend { display: flex; gap: 8px; flex-wrap: wrap; padding: 10px 12px; background: #f8fafc; border-radius: 8px; margin-bottom: 12px; }
  .kpi-legend-item { display: flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; }

  /* ── Formula Tooltip ── */
  .formula-wrap { position: relative; cursor: help; }
  .formula-wrap::after { content: "?"; position: absolute; top: -6px; right: -6px; width: 14px; height: 14px; background: #94a3b8; color: white; border-radius: 50%; font-size: 9px; font-weight: 800; display: flex; align-items: center; justify-content: center; line-height: 14px; text-align: center; }
  .formula-tooltip {
    display: none; position: fixed;
    background: #0f172a; color: white; border-radius: 10px; padding: 12px 14px;
    width: 260px; font-size: 12px; line-height: 1.6; z-index: 9999;
    box-shadow: 0 8px 24px rgba(0,0,0,.3); pointer-events: none;
  }
  .formula-tooltip::after {
    content: ""; position: absolute; left: 50%; transform: translateX(-50%);
    border: 6px solid transparent;
  }
  .formula-tooltip.tt-above { bottom: auto; }
  .formula-tooltip.tt-above::after { top: 100%; border-top-color: #0f172a; border-bottom-color: transparent; }
  .formula-tooltip.tt-below { top: auto; }
  .formula-tooltip.tt-below::after { bottom: 100%; border-bottom-color: #0f172a; border-top-color: transparent; }
  .ft-title { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .6px; color: #94a3b8; margin-bottom: 6px; }
  .ft-formula { font-family: monospace; font-size: 12px; color: #e2e8f0; margin-bottom: 8px; }
  .ft-inputs { font-size: 11px; color: #94a3b8; border-top: 1px solid #1e293b; padding-top: 6px; }
  .ft-inputs span { color: #f1f5f9; font-weight: 600; }
  .ft-result { margin-top: 6px; font-weight: 700; font-size: 13px; }

  /* ── Empty ── */
  .empty { text-align: center; padding: 48px; color: var(--text-muted); }

  @media (max-width: 768px) {
    .main { padding: 16px; }
    .kpi-bar { grid-template-columns: 1fr 1fr; }
    .score-banner { flex-direction: column; }
    .divider { width: 100%; height: 1px; }
  }
</style>
</head>
<body>

<header class="app-header">
  <div>
    <div class="app-header h1">ETG Portfolio Health Dashboard</div>
    <div class="sub">Enterprise Tool Governance · Powered by Torii</div>
  </div>
  <div class="last-refresh" id="refreshTs"></div>
</header>

<div class="main">

  <!-- Controls -->
  <div class="controls">
    <label>Owner</label>
    <select id="ownerFilter" onchange="applyFilters()">
      <option value="">All Portfolio Owners</option>
    </select>
    <label>Status</label>
    <select id="statusFilter" onchange="applyFilters()">
      <option value="">All</option>
      <option value="green">Green (Healthy)</option>
      <option value="yellow">Yellow (At Risk)</option>
      <option value="red">Red (Critical)</option>
    </select>
    <label>Search</label>
    <input type="text" id="searchInput" placeholder="Tool name…" oninput="applyFilters()" style="width:180px" />
    <div class="spacer"></div>
    <div class="legend">
      <div class="legend-item"><div class="legend-dot" style="background:var(--green)"></div>Healthy</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--yellow)"></div>At Risk</div>
      <div class="legend-item"><div class="legend-dot" style="background:var(--red)"></div>Critical</div>
    </div>
    <button class="btn btn-ghost" onclick="exportCSV()">Export CSV</button>
  </div>

  <!-- KPI Stats Bar -->
  <div class="kpi-bar" id="kpiBar"></div>

  <!-- Score Banner -->
  <div class="score-banner" id="scoreBanner"></div>

  <!-- Owner Cards -->
  <div class="section-title">
    Portfolio by Owner
    <span class="count" id="ownerCount"></span>
    <span style="font-size:11px;color:var(--text-muted);font-weight:400;margin-left:4px">Click a card to filter</span>
  </div>
  <div class="owner-grid" id="ownerGrid"></div>

  <!-- Category Chart + Overlap (full-portfolio view only) -->
  <div class="insight-row" id="insightRow">
    <div class="panel">
      <div class="panel-header">
        Tools by Category
        <span class="count" id="catCount"></span>
      </div>
      <div class="panel-body" id="categoryChart"></div>
    </div>
    <div class="panel">
      <div class="panel-header">
        Capability Overlap Detector
        <span class="count" id="overlapCount" style="background:#fee2e2;color:#dc2626"></span>
      </div>
      <div class="panel-body" id="overlapPanel"></div>
    </div>
  </div>

  <!-- Tool Table -->
  <div class="table-wrap">
    <div class="table-header-row">
      <div class="section-title" style="margin-bottom:0">
        Tool Registry <span class="count" id="toolCount"></span>
      </div>
      <div style="font-size:12px;color:var(--text-muted)">Composite = avg of 4 metrics</div>
    </div>
    <table>
      <thead>
        <tr>
          <th onclick="sortTable('name')">Tool <span class="sort-icon">↕</span></th>
          <th onclick="sortTable('owner')">Portfolio Owner <span class="sort-icon">↕</span></th>
          <th onclick="sortTable('category')">Category <span class="sort-icon">↕</span></th>
          <th onclick="sortTable('adoption')">Adoption <span class="sort-icon">↕</span></th>
          <th onclick="sortTable('spendEfficiency')">Spend Eff. <span class="sort-icon">↕</span></th>
          <th onclick="sortTable('contractRisk')">Contract Risk <span class="sort-icon">↕</span></th>
          <th onclick="sortTable('dataCompleteness')">Data Compl. <span class="sort-icon">↕</span></th>
          <th onclick="sortTable('composite')">Health Score <span class="sort-icon">↕</span></th>
          <th></th>
        </tr>
      </thead>
      <tbody id="toolBody"></tbody>
    </table>
    <div class="pagination" id="pagination"></div>
  </div>
</div>

<!-- Detail Modal -->
<div class="modal-backdrop" id="modal" onclick="closeModalOnBackdrop(event)">
  <div class="modal">
    <div class="modal-header">
      <h2 id="modalTitle"></h2>
      <button class="modal-close" onclick="closeModal()">✕</button>
    </div>
    <div class="modal-body" id="modalBody"></div>
  </div>
</div>

<script>
// ─────────────────────────────────────────────────────────────────────────────
// DATA
// ─────────────────────────────────────────────────────────────────────────────
const RAW_TOOLS = [
  { id:1,  name:"Salesforce",         category:"CRM",                          owner:"Sarah Mitchell", licenseModel:"per_seat",   activeUsers:210,  licensedSeats:250,  eligiblePop:250,  annualCost:187500,  contractStart:"2024-01-15", contractEnd:"2026-01-15", autoRenew:true,  hasContract:true,  hasOwner:true,  hasCostCenter:true,  hasJustification:true  },
  { id:2,  name:"Workday",            category:"HRIS Platform",                owner:"Sarah Mitchell", licenseModel:"platform",   activeUsers:1800, licensedSeats:0,    eligiblePop:2000, annualCost:420000,  contractStart:"2023-06-01", contractEnd:"2026-06-01", autoRenew:false, hasContract:true,  hasOwner:true,  hasCostCenter:true,  hasJustification:true  },
  { id:3,  name:"Slack",              category:"Collaboration & Messaging",    owner:"James Rivera",   licenseModel:"unlimited",  activeUsers:1650, licensedSeats:0,    eligiblePop:2000, annualCost:132000,  contractStart:"2024-03-01", contractEnd:"2025-03-01", autoRenew:true,  hasContract:true,  hasOwner:true,  hasCostCenter:true,  hasJustification:true  },
  { id:4,  name:"Zoom",               category:"Video Conferencing",           owner:"James Rivera",   licenseModel:"per_seat",   activeUsers:890,  licensedSeats:1200, eligiblePop:1200, annualCost:72000,   contractStart:"2024-07-01", contractEnd:"2025-07-01", autoRenew:true,  hasContract:true,  hasOwner:true,  hasCostCenter:true,  hasJustification:false },
