// Overlap groups — capability redundancy flags
const OVERLAP_GROUPS = [
  { category:"Knowledge Management",         risk:"high",   toolIds:[7,18,40], note:"3 tools (Confluence, Notion, Guru) serve overlapping wiki/knowledge-base use cases across 3 different owner portfolios." },
  { category:"Performance Management",       risk:"high",   toolIds:[29,31],   note:"Lattice and Leapsome are functionally duplicative and owned by the same portfolio owner (Priya Patel)." },
  { category:"Visual Collaboration",         risk:"medium", toolIds:[16,35],   note:"Miro and Lucidchart overlap on whiteboarding and diagramming across Kevin Park and Marcus Johnson portfolios." },
  { category:"Procurement / Intake",         risk:"medium", toolIds:[15,34],   note:"Coupa and Zip both handle procurement intake workflows. Consolidation opportunity across Rachel Kim and Nicole Warren." },
  { category:"Monitoring & Observability",   risk:"medium", toolIds:[12,21],   note:"Splunk and Datadog have significant log management and alerting overlap across Lisa Thompson and Tom Bradley." },
  { category:"Contract & eSignature",        risk:"low",    toolIds:[13,14],   note:"DocuSign handles eSignature while Ironclad handles CLM — some workflow overlap; both owned by Rachel Kim." },
  { category:"Customer Engagement",          risk:"low",    toolIds:[22,23],   note:"Zendesk (support) and Intercom (proactive engagement) overlap on in-app messaging — validate distinct use cases." },
];

// ─────────────────────────────────────────────────────────────────────────────
// SCORING ENGINE
// ─────────────────────────────────────────────────────────────────────────────
const TODAY = new Date();

function daysUntil(d) { return d ? Math.round((new Date(d) - TODAY) / 86400000) : null; }

function scoreAdoption(t) {
  if (t.licenseModel === "per_seat") {
    if (!t.licensedSeats) return { score:null, label:"No seats defined" };
    const s = Math.min(100, Math.round((t.activeUsers / t.licensedSeats) * 100));
    return { score:s, label:`${t.activeUsers} / ${t.licensedSeats} seats` };
  }
  if (t.licenseModel === "consumption") {
    const b = t.budgetUsed || 0;
    return { score: b > 1 ? 100 : Math.min(100, Math.round(b*100)), label:`${Math.round(b*100)}% budget used` };
  }
  if (!t.eligiblePop) return { score:null, label:"No eligible pop" };
  return { score: Math.min(100, Math.round((t.activeUsers/t.eligiblePop)*100)), label:`${t.activeUsers} / ${t.eligiblePop} eligible` };
}

function scoreSpend(t) {
  if (t.licenseModel === "consumption") {
    const b = t.budgetUsed || 0;
    const s = b > 1 ? Math.max(0, Math.round((2-b)*100)) : Math.round(b*100);
    return { score:s, label:`${(t.annualCost/12).toLocaleString("en-US",{style:"currency",currency:"USD",maximumFractionDigits:0})}/mo · ${Math.round(b*100)}% utilized` };
  }
  if (!t.activeUsers) return { score:0, label:"No active users" };
  const denom = t.licensedSeats || t.eligiblePop || 1;
  const s = Math.min(100, Math.round((t.activeUsers/denom)*100));
  return { score:s, label:`$${Math.round(t.annualCost/t.activeUsers).toLocaleString()}/active vs $${Math.round(t.annualCost/denom).toLocaleString()}/seat` };
}

function scoreContract(t) {
  const days = daysUntil(t.contractEnd);
  let base = days === null ? 0 : days > 180 ? 100 : days > 90 ? 75 : days > 60 ? 55 : days > 30 ? 35 : days > 0 ? 15 : 0;
  const s = Math.max(0, base - (t.autoRenew ? 15 : 0) - (!t.hasContract ? 25 : 0));
  const dStr = days === null ? "No date" : days < 0 ? "Expired" : `${days}d to renewal`;
  const flags = [t.autoRenew && "auto-renew", !t.hasContract && "no contract"].filter(Boolean);
  return { score:s, label:dStr + (flags.length ? ` · ${flags.join(", ")}` : ""), daysToRenewal:days };
}

function scoreCompleteness(t) {
  let pts = 0;
  if (t.hasContract)  pts += 20;
  if (t.contractStart) pts += 15;
  if (t.contractEnd)   pts += 15;
  if (t.hasOwner)      pts += 20;
  if (t.licensedSeats > 0 || t.eligiblePop > 0 || t.licenseModel==="consumption") pts += 15;
  if (t.hasCostCenter) pts += 10;
  if (t.hasJustification) pts += 5;
  return { score:pts, label:`${pts} / 100 pts` };
}

function gradeScore(s, metric) {
  if (metric === "completeness") return s >= 90 ? "green" : s >= 70 ? "yellow" : "red";
  return s >= 70 ? "green" : s >= 40 ? "yellow" : "red";
}

function enrichTool(t) {
  const adoption    = scoreAdoption(t);
  const spend       = scoreSpend(t);
  const contract    = scoreContract(t);
  const completeness= scoreCompleteness(t);
  const vals        = [adoption.score, spend.score, contract.score, completeness.score].filter(v => v !== null);
  const composite   = vals.length ? Math.round(vals.reduce((a,b)=>a+b,0)/vals.length) : 0;
  return {
    ...t,
    scores:{ adoption, spend, contract, completeness },
    composite,
    health: gradeScore(composite, null),
    adoptionGrade:     gradeScore(adoption.score ?? 0, "adoption"),
    spendGrade:        gradeScore(spend.score, "spend"),
    contractGrade:     gradeScore(contract.score, "contract"),
    completenessGrade: gradeScore(completeness.score, "completeness"),
  };
}

const TOOLS = RAW_TOOLS.map(enrichTool);

// ─────────────────────────────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────────────────────────────
let filteredTools = [...TOOLS];
let activeOwner = null;
let sortKey = "composite", sortDir = -1, page = 1;
const PAGE_SIZE = 15;

// ─────────────────────────────────────────────────────────────────────────────
// HELPERS
// ─────────────────────────────────────────────────────────────────────────────
const colorClass = g => ({ green:"chip-green", yellow:"chip-yellow", red:"chip-red" }[g] || "chip-gray");
const colorHex   = g => ({ green:"var(--green)", yellow:"var(--yellow)", red:"var(--red)" }[g] || "var(--gray)");
const colorBg    = g => ({ green:"var(--green-bg)", yellow:"var(--yellow-bg)", red:"var(--red-bg)" }[g] || "var(--gray-bg)");
const labelOf    = g => ({ green:"Healthy", yellow:"At Risk", red:"Critical" }[g] || "N/A");
const fmt$       = v => v.toLocaleString("en-US",{style:"currency",currency:"USD",maximumFractionDigits:0});

function renderChip(score, g) {
  if (score === null) return `<span class="chip chip-gray"><span class="dot"></span>N/A</span>`;
  return `<span class="chip ${colorClass(g)}"><span class="dot"></span>${score}</span>`;
}
function renderBar(score, g) {
  if (score === null) return `<div class="score-bar-wrap"><div class="score-bar"></div><span class="score-val" style="color:var(--gray)">N/A</span></div>`;
  return `<div class="score-bar-wrap"><div class="score-bar"><div class="score-bar-inner" style="width:${score}%;background:${colorHex(g)}"></div></div><span class="score-val" style="color:${colorHex(g)}">${score}</span></div>`;
}

// ─────────────────────────────────────────────────────────────────────────────
// KPI BAR
// ─────────────────────────────────────────────────────────────────────────────
function renderKPIBar() {
  const set = filteredTools;

  // Total Spend
  const totalSpend = set.reduce((a,t) => a + t.annualCost, 0);

  // Wasted Spend — unused seat cost on per_seat tools
  let wastedSpend = 0;
  set.forEach(t => {
    if (t.licenseModel === "per_seat" && t.licensedSeats > 0) {
      const unused = Math.max(0, t.licensedSeats - t.activeUsers);
      wastedSpend += t.annualCost * (unused / t.licensedSeats);
    }
  });
  const defensiblePct = totalSpend > 0 ? Math.round(((totalSpend - wastedSpend) / totalSpend) * 100) : 100;

  // Tool counts
  const greenCt  = set.filter(t=>t.health==="green").length;
  const yellowCt = set.filter(t=>t.health==="yellow").length;
  const redCt    = set.filter(t=>t.health==="red").length;

  // Renewals
  const within30  = set.filter(t => { const d = daysUntil(t.contractEnd); return d !== null && d >= 0 && d <= 30; });
  const within90  = set.filter(t => { const d = daysUntil(t.contractEnd); return d !== null && d > 30 && d <= 90; });

  document.getElementById("kpiBar").innerHTML = `
    <div class="kpi-card">
      <div class="kc-label">Total Annual Spend</div>
      <div class="kc-value">${totalSpend >= 1000000 ? "$" + (totalSpend/1000000).toFixed(1) + "M" : fmt$(totalSpend)}</div>
      <div class="kc-sub">across ${set.length} tool${set.length!==1?"s":""}</div>
    </div>
    <div class="kpi-card">
      <div class="kc-label">Defensible Spend</div>
      <div class="kc-value" style="color:${defensiblePct>=80?"var(--green)":defensiblePct>=60?"var(--yellow)":"var(--red)"}">${defensiblePct}%</div>
      <div class="kc-sub warn">${fmt$(Math.round(wastedSpend))} wasted on inactive seats</div>
    </div>
    <div class="kpi-card">
      <div class="kc-label">Tools in Portfolio</div>
      <div class="kc-value">${set.length}</div>
      <div class="kc-dots">
        <div class="kc-dot" style="background:var(--green)"></div>${greenCt} Healthy &nbsp;
        <div class="kc-dot" style="background:var(--yellow)"></div>${yellowCt} At Risk &nbsp;
        <div class="kc-dot" style="background:var(--red)"></div>${redCt} Critical
      </div>
    </div>
    <div class="kpi-card">
      <div class="kc-label">Renewal Alerts</div>
      <div class="kc-value" style="color:${within30.length>0?"var(--red)":"var(--text)"}">${within30.length}<span style="font-size:16px;font-weight:500;color:var(--text-muted)"> + ${within90.length}</span></div>
      <div class="renewal-row">
        ${within30.length ? `<span class="renewal-badge" style="background:var(--red-bg);color:var(--red)">${within30.length} renewing ≤30d</span>` : `<span class="renewal-badge" style="background:var(--green-bg);color:var(--green)">None critical</span>`}
        ${within90.length ? `<span class="renewal-badge" style="background:var(--yellow-bg);color:var(--yellow)">${within90.length} within 90d</span>` : ""}
      </div>
    </div>
  `;
}

// ─────────────────────────────────────────────────────────────────────────────
// SCORE BANNER
// ─────────────────────────────────────────────────────────────────────────────
function renderBanner() {
  const set = filteredTools.length ? filteredTools : TOOLS;
  const avg = Math.round(set.reduce((a,t)=>a+t.composite,0)/set.length);
  const g   = gradeScore(avg, null);
  const adoptSet = set.filter(t=>t.scores.adoption.score!==null);
  const avgA = adoptSet.length ? Math.round(adoptSet.reduce((a,t)=>a+t.scores.adoption.score,0)/adoptSet.length) : 0;
  const avgSp = Math.round(set.reduce((a,t)=>a+t.scores.spend.score,0)/set.length);
  const avgCo = Math.round(set.reduce((a,t)=>a+t.scores.contract.score,0)/set.length);
  const avgCm = Math.round(set.reduce((a,t)=>a+t.scores.completeness.score,0)/set.length);
  const metrics = [
    { name:"Adoption Rate",     score:avgA,  g:gradeScore(avgA,"adoption"),         desc:"Active vs. licensed/eligible" },
    { name:"Spend Efficiency",  score:avgSp, g:gradeScore(avgSp,"spend"),           desc:"Cost per active user" },
    { name:"Contract Risk",     score:avgCo, g:gradeScore(avgCo,"contract"),        desc:"Renewal & auto-renew exposure" },
    { name:"Data Completeness", score:avgCm, g:gradeScore(avgCm,"completeness"),    desc:"Governance fields filled" },
  ];
  const ctx = activeOwner ? ` · ${activeOwner}` : " · Full Portfolio";
  document.getElementById("scoreBanner").innerHTML = `
    <div class="portfolio-score-block">
      <div class="score-label">Portfolio Health Score${ctx}</div>
      <div class="big-score" style="color:${colorHex(g)}">${avg}</div>
      <div class="score-grade ${colorClass(g)}">${labelOf(g)}</div>
      <div style="font-size:11px;color:var(--text-muted);margin-top:8px">${set.length} tools · ${set.filter(t=>t.health==="green").length}G / ${set.filter(t=>t.health==="yellow").length}Y / ${set.filter(t=>t.health==="red").length}R</div>
    </div>
    <div class="divider"></div>
    <div class="metric-pills">
      ${metrics.map(m=>`
        <div class="metric-pill formula-wrap formula-wrap-down" style="border-color:${colorHex(m.g)};background:${colorBg(m.g)};cursor:help">
          ${buildPortfolioMetricTooltip(m.key, set)}
          <div class="mp-label">${m.name}</div>
          <div class="mp-score" style="color:${colorHex(m.g)}">${m.score}</div>
          <div class="mp-name">${m.desc}</div>
          <div class="mp-bar"><div class="mp-bar-fill" style="width:${m.score}%;background:${colorHex(m.g)}"></div></div>
        </div>
      `).join("")}
    </div>
  `;
}

// ─────────────────────────────────────────────────────────────────────────────
// OWNER GRID
// ─────────────────────────────────────────────────────────────────────────────
function renderOwnerGrid() {
  const owners = {};
  TOOLS.forEach(t => { (owners[t.owner] = owners[t.owner] || []).push(t); });
  const list = Object.entries(owners).map(([name, tools]) => {
    const avg = Math.round(tools.reduce((a,t)=>a+t.composite,0)/tools.length);
    return { name, tools, avg, g: gradeScore(avg, null) };
  }).sort((a,b) => b.avg - a.avg);

  const sel = document.getElementById("ownerFilter");
  sel.innerHTML = '<option value="">All Portfolio Owners</option>';
  list.forEach(o => { sel.innerHTML += `<option value="${o.name}">${o.name}</option>`; });
  if (activeOwner) sel.value = activeOwner;
  document.getElementById("ownerCount").textContent = list.length;

  document.getElementById("ownerGrid").innerHTML = list.map(o => `
    <div class="owner-card ${activeOwner===o.name?"active":""}" onclick="toggleOwner('${o.name}')">
      <div class="oc-badge ${colorClass(o.g)}">${labelOf(o.g)}</div>
      <div class="oc-name">${o.name}</div>
      <div class="oc-score" style="color:${colorHex(o.g)}">${o.avg}</div>
      <div class="oc-meta">${o.tools.length} tools · ${o.tools.filter(t=>t.health==="red").length} critical</div>
    </div>
  `).join("");
}

// ─────────────────────────────────────────────────────────────────────────────
// CATEGORY CHART
// ─────────────────────────────────────────────────────────────────────────────
function renderCategoryChart() {
  const set = filteredTools;
  const cats = {};
  set.forEach(t => {
    if (!cats[t.category]) cats[t.category] = { tools:[], spend:0 };
    cats[t.category].tools.push(t);
    cats[t.category].spend += t.annualCost;
  });

  const list = Object.entries(cats).map(([name, d]) => {
    const avgH = Math.round(d.tools.reduce((a,t)=>a+t.composite,0)/d.tools.length);
    return { name, count: d.tools.length, spend: d.spend, avgHealth: avgH, g: gradeScore(avgH, null) };
  }).sort((a,b) => b.spend - a.spend);

  const maxSpend = list[0]?.spend || 1;
  document.getElementById("catCount").textContent = `${list.length} categories`;

  const totalSpend = set.reduce((a,t)=>a+t.annualCost,0);

  document.getElementById("categoryChart").innerHTML = `
    <div class="chart-legend">
      <div class="chart-legend-item"><div class="chart-legend-swatch" style="background:var(--green)"></div>Healthy avg score</div>
      <div class="chart-legend-item"><div class="chart-legend-swatch" style="background:var(--yellow)"></div>At Risk</div>
      <div class="chart-legend-item"><div class="chart-legend-swatch" style="background:var(--red)"></div>Critical</div>
    </div>
    ${list.map(c => `
      <div class="cat-row">
        <div class="cat-name" title="${c.name}">${c.name}</div>
        <div class="cat-bar-wrap">
          <div class="cat-bar-fill" style="width:${Math.round((c.spend/maxSpend)*100)}%;background:${colorHex(c.g)}">
            <span class="cat-bar-label">${c.count} tool${c.count!==1?"s":""} · ${c.avgHealth}</span>
          </div>
        </div>
        <div class="cat-meta">${c.spend >= 1000000 ? "$"+(c.spend/1000000).toFixed(1)+"M" : "$"+(c.spend/1000).toFixed(0)+"K"}</div>
      </div>
    `).join("")}
    <div style="font-size:11px;color:var(--text-muted);margin-top:12px;text-align:right">Bar width = annual spend · Label = tool count + avg health score</div>
  `;
}

// ─────────────────────────────────────────────────────────────────────────────
// OVERLAP PANEL
// ─────────────────────────────────────────────────────────────────────────────
function renderOverlapPanel() {
  const set = filteredTools;
  const setIds = new Set(set.map(t=>t.id));

  // Only show groups where ≥2 tools are in the current filtered set
  const visible = OVERLAP_GROUPS.map(g => ({
    ...g,
    tools: g.toolIds.map(id => TOOLS.find(t=>t.id===id)).filter(t => t && setIds.has(t.id))
  })).filter(g => g.tools.length >= 2);

  document.getElementById("overlapCount").textContent = `${visible.length} overlap${visible.length!==1?"s":""}`;

  if (!visible.length) {
    document.getElementById("overlapPanel").innerHTML = `<div class="empty"><div style="font-size:28px">✓</div><div style="margin-top:6px;font-size:13px">No overlapping capabilities detected in current filter.</div></div>`;
    return;
  }

  const combinedWaste = visible.reduce((a,g) => a + g.tools.reduce((b,t)=>b+t.annualCost,0), 0);

  document.getElementById("overlapPanel").innerHTML = `
    <div style="font-size:12px;color:var(--text-muted);margin-bottom:12px">
      ${visible.length} capability overlap${visible.length!==1?"s":""}  ·  ${fmt$(combinedWaste)} combined spend at risk of redundancy
    </div>
    ${visible.map(g => `
      <div class="overlap-card" style="border-color:${g.risk==="high"?"var(--red-border)":g.risk==="medium"?"var(--yellow-border)":"var(--gray-border)"}">
        <div class="overlap-header">
          <div class="overlap-cat">${g.category}</div>
          <div class="overlap-risk risk-${g.risk}">${g.risk.charAt(0).toUpperCase()+g.risk.slice(1)} Risk</div>
        </div>
        <div class="overlap-tools">
          ${g.tools.map(t=>`<span class="overlap-tool-tag" onclick="openModal(${t.id})" style="cursor:pointer" title="Click for details">${t.name} (${t.owner.split(" ")[0]})</span>`).join("")}
        </div>
        <div class="overlap-note">${g.note}</div>
        <div class="overlap-cost">Combined spend: ${fmt$(g.tools.reduce((a,t)=>a+t.annualCost,0))}/yr</div>
      </div>
    `).join("")}
  `;
}

// ─────────────────────────────────────────────────────────────────────────────
// TOOL TABLE
// ─────────────────────────────────────────────────────────────────────────────
function renderTable() {
  const start = (page-1)*PAGE_SIZE, end = start+PAGE_SIZE;
  const rows = filteredTools.slice(start, end);
  const ML = { per_seat:"Per Seat", unlimited:"Unlimited", consumption:"Consumption", flat_fee:"Flat Fee", platform:"Platform", outcome_based:"Outcome-Based" };

  document.getElementById("toolCount").textContent = `${filteredTools.length} tools`;
  document.getElementById("toolBody").innerHTML = rows.length ? rows.map(t => `
    <tr>
      <td><div class="tool-name">${t.name}</div><div class="tool-sub">${t.category}</div></td>
      <td style="font-size:13px">${t.owner}</td>
      <td style="font-size:12px;color:var(--text-muted)">${ML[t.licenseModel]||t.licenseModel||"—"}</td>
      <td>${renderBar(t.scores.adoption.score, t.adoptionGrade)}</td>
      <td>${renderBar(t.scores.spend.score, t.spendGrade)}</td>
      <td>${renderBar(t.scores.contract.score, t.contractGrade)}</td>
      <td>${renderBar(t.scores.completeness.score, t.completenessGrade)}</td>
      <td>${renderChip(t.composite, t.health)}</td>
      <td><button class="btn btn-ghost" style="padding:4px 10px;font-size:11px" onclick="openModal(${t.id})">Detail</button></td>
    </tr>
  `).join("") : `<tr><td colspan="9"><div class="empty">No tools match your filters.</div></td></tr>`;

  renderPagination();
}

function renderPagination() {
  const total = Math.ceil(filteredTools.length / PAGE_SIZE);
  if (total <= 1) { document.getElementById("pagination").innerHTML = ""; return; }
  let h = "";
  for (let i=1;i<=total;i++) h += `<button class="page-btn ${i===page?"active":""}" onclick="setPage(${i})">${i}</button>`;
  document.getElementById("pagination").innerHTML = h;
}

// ─────────────────────────────────────────────────────────────────────────────
// RENDER ALL
// ─────────────────────────────────────────────────────────────────────────────
function render() {
  renderKPIBar();
  renderBanner();
  renderOwnerGrid();
  renderCategoryChart();
  renderOverlapPanel();
  renderTable();
}

// ─────────────────────────────────────────────────────────────────────────────
// INTERACTIONS
// ─────────────────────────────────────────────────────────────────────────────
function applyFilters() {
  const ownerSel  = document.getElementById("ownerFilter").value;
  const statusSel = document.getElementById("statusFilter").value;
  const search    = document.getElementById("searchInput").value.toLowerCase();
  activeOwner = ownerSel || null;
  page = 1;
  filteredTools = TOOLS.filter(t => {
    if (ownerSel  && t.owner !== ownerSel) return false;
    if (statusSel && t.health !== statusSel) return false;
    if (search    && !t.name.toLowerCase().includes(search)) return false;
    return true;
  });
  sortTools();
  render();
}

function toggleOwner(name) {
  activeOwner = activeOwner === name ? null : name;
  document.getElementById("ownerFilter").value = activeOwner || "";
  applyFilters();
}

function sortTable(key) {
  sortDir = sortKey === key ? sortDir * -1 : -1;
  sortKey = key;
  sortTools();
  renderTable();
}

function sortTools() {
  filteredTools.sort((a,b) => {
    let va, vb;
    if      (sortKey==="composite")       { va=a.composite; vb=b.composite; }
    else if (sortKey==="adoption")        { va=a.scores.adoption.score??-1; vb=b.scores.adoption.score??-1; }
    else if (sortKey==="spendEfficiency") { va=a.scores.spend.score; vb=b.scores.spend.score; }
    else if (sortKey==="contractRisk")    { va=a.scores.contract.score; vb=b.scores.contract.score; }
    else if (sortKey==="dataCompleteness"){ va=a.scores.completeness.score; vb=b.scores.completeness.score; }
    else if (sortKey==="name")            { va=a.name.toLowerCase(); vb=b.name.toLowerCase(); }
    else if (sortKey==="owner")           { va=a.owner.toLowerCase(); vb=b.owner.toLowerCase(); }
    else if (sortKey==="category")        { va=a.category.toLowerCase(); vb=b.category.toLowerCase(); }
    else                                  { va=a[sortKey]; vb=b[sortKey]; }
    return va < vb ? sortDir : va > vb ? -sortDir : 0;
  });
}

function setPage(p) { page = p; renderTable(); }

// ─────────────────────────────────────────────────────────────────────────────
// ADOPTION FORMULA TOOLTIP
// ─────────────────────────────────────────────────────────────────────────────
function tooltipScoreColor(s) {
  return s >= 70 ? '#4ade80' : s >= 40 ? '#facc15' : '#f87171';
}

function buildPortfolioMetricTooltip(key, set) {
  const sc = s => tooltipScoreColor(s);

  if (key === 'adoption') {
    const scoreable = set.filter(t => t.scores.adoption.score !== null);
    const avg = scoreable.length ? Math.round(scoreable.reduce((a,t)=>a+t.scores.adoption.score,0)/scoreable.length) : 0;
    const green  = scoreable.filter(t=>t.scores.adoption.score>=70).length;
    const yellow = scoreable.filter(t=>t.scores.adoption.score>=40&&t.scores.adoption.score<70).length;
    const red    = scoreable.filter(t=>t.scores.adoption.score<40).length;
    const noData = set.length - scoreable.length;
    const totalActive   = set.reduce((a,t)=>a+(t.activeUsers||0),0);
    const totalLicensed = set.filter(t=>t.licensedSeats>0).reduce((a,t)=>a+t.licensedSeats,0);
    return `<div class="formula-tooltip">
      <div class="ft-title">Adoption Rate — Portfolio Avg</div>
      <div class="ft-formula">Avg of all tool adoption scores</div>
      <div class="ft-inputs">
        Tools scored: <span>${scoreable.length} of ${set.length}</span>${noData ? ` &nbsp;·&nbsp; <span style="color:#f87171">${noData} missing seat data</span>` : ''}<br>
        Total active users: <span>${totalActive.toLocaleString()}</span><br>
        Total licensed seats: <span>${totalLicensed.toLocaleString()}</span><br>
        <span style="color:#4ade80">●</span> ≥70: ${green} tools &nbsp;
        <span style="color:#facc15">●</span> 40–69: ${yellow} &nbsp;
        <span style="color:#f87171">●</span> &lt;40: ${red}
      </div>
      <div class="ft-result">Portfolio avg = <span style="color:${sc(avg)}">${avg}</span></div>
    </div>`;
  }

  if (key === 'spend') {
    const avg = Math.round(set.reduce((a,t)=>a+t.scores.spend.score,0)/set.length);
    const totalSpend = set.reduce((a,t)=>a+t.annualCost,0);
    let wasted = 0;
    set.forEach(t => {
      if (t.licenseModel==='per_seat' && t.licensedSeats>0)
        wasted += t.annualCost * Math.max(0, t.licensedSeats - t.activeUsers) / t.licensedSeats;
    });
    const defPct = totalSpend > 0 ? Math.round(((totalSpend-wasted)/totalSpend)*100) : 100;
    const green  = set.filter(t=>t.scores.spend.score>=70).length;
    const yellow = set.filter(t=>t.scores.spend.score>=40&&t.scores.spend.score<70).length;
    const red    = set.filter(t=>t.scores.spend.score<40).length;
    return `<div class="formula-tooltip">
      <div class="ft-title">Spend Efficiency — Portfolio Avg</div>
      <div class="ft-formula">Avg of (Active Users ÷ Seats) × 100 per tool</div>
      <div class="ft-inputs">
        Total annual spend: <span>${fmt$(totalSpend)}</span><br>
        Wasted on unused seats: <span style="color:#f87171">${fmt$(Math.round(wasted))}</span><br>
        Defensible spend: <span style="color:#4ade80">${defPct}%</span><br>
        <span style="color:#4ade80">●</span> ≥70: ${green} tools &nbsp;
        <span style="color:#facc15">●</span> 40–69: ${yellow} &nbsp;
        <span style="color:#f87171">●</span> &lt;40: ${red}
      </div>
      <div class="ft-result">Portfolio avg = <span style="color:${sc(avg)}">${avg}</span></div>
    </div>`;
  }

  if (key === 'contract') {
    const avg = Math.round(set.reduce((a,t)=>a+t.scores.contract.score,0)/set.length);
    const autoRenew   = set.filter(t=>t.autoRenew).length;
    const noContract  = set.filter(t=>!t.hasContract).length;
    const expiring30  = set.filter(t=>{ const d=daysUntil(t.contractEnd); return d!==null&&d>=0&&d<=30; }).length;
    const expiring90  = set.filter(t=>{ const d=daysUntil(t.contractEnd); return d!==null&&d>30&&d<=90; }).length;
    const green  = set.filter(t=>t.scores.contract.score>=70).length;
    const yellow = set.filter(t=>t.scores.contract.score>=40&&t.scores.contract.score<70).length;
    const red    = set.filter(t=>t.scores.contract.score<40).length;
    return `<div class="formula-tooltip">
      <div class="ft-title">Contract Risk — Portfolio Avg</div>
      <div class="ft-formula">Avg of (Renewal Score − Penalties) per tool</div>
      <div class="ft-inputs">
        Auto-renew active: <span style="color:${autoRenew?'#f87171':'#4ade80'}">${autoRenew} tool${autoRenew!==1?'s':''}</span> (−15pts each)<br>
        No contract on file: <span style="color:${noContract?'#f87171':'#4ade80'}">${noContract} tool${noContract!==1?'s':''}</span> (−25pts each)<br>
        Expiring ≤30d: <span style="color:${expiring30?'#f87171':'#4ade80'}">${expiring30} tool${expiring30!==1?'s':''}</span><br>
        Expiring 31–90d: <span style="color:${expiring90?'#facc15':'#4ade80'}">${expiring90} tool${expiring90!==1?'s':''}</span><br>
        <span style="color:#4ade80">●</span> ≥70: ${green} &nbsp;
        <span style="color:#facc15">●</span> 40–69: ${yellow} &nbsp;
        <span style="color:#f87171">●</span> &lt;40: ${red}
      </div>
      <div class="ft-result">Portfolio avg = <span style="color:${sc(avg)}">${avg}</span></div>
    </div>`;
  }

  if (key === 'completeness') {
    const avg = Math.round(set.reduce((a,t)=>a+t.scores.completeness.score,0)/set.length);
    const clean  = set.filter(t=>t.scores.completeness.score>=90).length;
    const gaps   = set.filter(t=>t.scores.completeness.score>=70&&t.scores.completeness.score<90).length;
    const ungov  = set.filter(t=>t.scores.completeness.score<70).length;
    const noContract    = set.filter(t=>!t.hasContract).length;
    const noOwner       = set.filter(t=>!t.hasOwner).length;
    const noCostCenter  = set.filter(t=>!t.hasCostCenter).length;
    const noJustification = set.filter(t=>!t.hasJustification).length;
    return `<div class="formula-tooltip" style="width:290px">
      <div class="ft-title">Data Completeness — Portfolio Avg</div>
      <div class="ft-formula">Avg of (Fields Present ÷ 100pts) per tool</div>
      <div class="ft-inputs">
        <span style="color:#4ade80">Clean (≥90):</span> ${clean} tools<br>
        <span style="color:#facc15">Gaps (70–89):</span> ${gaps} tools<br>
        <span style="color:#f87171">Ungovernable (&lt;70):</span> ${ungov} tools<br>
        Most common gaps:<br>
        &nbsp;No contract: <span style="color:#f87171">${noContract}</span> &nbsp;·&nbsp;
        No owner: <span style="color:#f87171">${noOwner}</span><br>
        &nbsp;No cost center: <span style="color:#facc15">${noCostCenter}</span> &nbsp;·&nbsp;
        No justification: <span style="color:#facc15">${noJustification}</span>
      </div>
      <div class="ft-result">Portfolio avg = <span style="color:${sc(avg)}">${avg}</span></div>
    </div>`;
  }

  return '';
}

function buildAdoptionTooltip(t) {
  const s = t.scores.adoption;
  const scoreColor = s.score >= 70 ? '#4ade80' : s.score >= 40 ? '#facc15' : '#f87171';
  let formula, inputs, resultLine;

  if (t.licenseModel === 'per_seat') {
    formula = `(Active Users ÷ Licensed Seats) × 100`;
    inputs  = `Active Users = <span>${t.activeUsers.toLocaleString()}</span> &nbsp;·&nbsp; Licensed Seats = <span>${t.licensedSeats.toLocaleString()}</span>`;
    resultLine = s.score !== null
      ? `(${t.activeUsers.toLocaleString()} ÷ ${t.licensedSeats.toLocaleString()}) × 100 = <span style="color:${scoreColor}">${s.score}</span>`
      : `<span style="color:#f87171">No seat count defined</span>`;

  } else if (t.licenseModel === 'consumption') {
    const pct = Math.round((t.budgetUsed || 0) * 100);
    formula = `Budget Consumed ÷ Budget Allocated × 100`;
    inputs  = `Budget Used = <span>${pct}%</span> of allocated`;
    resultLine = `${pct}% utilized = <span style="color:${scoreColor}">${s.score}</span>`;

  } else {
    // platform, unlimited, flat_fee
    const modelMap = { platform:'Platform', unlimited:'Unlimited', flat_fee:'Flat Fee' };
    const mLabel = modelMap[t.licenseModel] || t.licenseModel;
    formula = `(Active Users ÷ Eligible Population) × 100`;
    inputs  = `Active Users = <span>${t.activeUsers.toLocaleString()}</span> &nbsp;·&nbsp; Eligible Pop. = <span>${(t.eligiblePop||0).toLocaleString()}</span> <br>Model: <span>${mLabel}</span> — eligible pop used as denominator`;
    resultLine = t.eligiblePop
      ? `(${t.activeUsers.toLocaleString()} ÷ ${t.eligiblePop.toLocaleString()}) × 100 = <span style="color:${scoreColor}">${s.score}</span>`
      : `<span style="color:#f87171">No eligible population defined</span>`;
  }

  return `<div class="formula-tooltip">
    <div class="ft-title">Adoption Rate Formula</div>
    <div class="ft-formula">${formula}</div>
    <div class="ft-inputs">${inputs}</div>
    <div class="ft-result">${resultLine}</div>
  </div>`;
}

function buildSpendTooltip(t) {
  const s = t.scores.spend;
  const sc = tooltipScoreColor(s.score);

  if (t.licenseModel === 'consumption') {
    const b = t.budgetUsed || 0;
    const pct = Math.round(b * 100);
    const over = b > 1;
    return `<div class="formula-tooltip">
      <div class="ft-title">Spend Efficiency Formula</div>
      <div class="ft-formula">${over ? '(2 − Budget Used Ratio) × 100' : 'Budget Used Ratio × 100'}</div>
      <div class="ft-inputs">
        Annual Cost = <span>${fmt$(t.annualCost)}</span><br>
        Budget Used = <span>${pct}%</span> ${over ? '— <span style="color:#f87171">over budget</span>' : ''}
      </div>
      <div class="ft-result">${over ? `(2 − ${b.toFixed(2)}) × 100` : `${b.toFixed(2)} × 100`} = <span style="color:${sc}">${s.score}</span></div>
    </div>`;
  }

  const denom = t.licensedSeats || t.eligiblePop || 1;
  const denomLabel = t.licensedSeats ? 'Licensed Seats' : 'Eligible Population';
  const costPerActive = t.activeUsers ? Math.round(t.annualCost / t.activeUsers) : 'N/A';
  const costPerSeat   = Math.round(t.annualCost / denom);
  return `<div class="formula-tooltip">
    <div class="ft-title">Spend Efficiency Formula</div>
    <div class="ft-formula">(Active Users ÷ ${denomLabel}) × 100</div>
    <div class="ft-inputs">
      Annual Cost = <span>${fmt$(t.annualCost)}</span><br>
      Cost / Active User = <span>$${typeof costPerActive === 'number' ? costPerActive.toLocaleString() : 'N/A'}</span>
      &nbsp;·&nbsp; Cost / Seat = <span>$${costPerSeat.toLocaleString()}</span><br>
      ${denomLabel} = <span>${denom.toLocaleString()}</span>
      &nbsp;·&nbsp; Active Users = <span>${t.activeUsers.toLocaleString()}</span>
    </div>
    <div class="ft-result">(${t.activeUsers.toLocaleString()} ÷ ${denom.toLocaleString()}) × 100 = <span style="color:${sc}">${s.score}</span></div>
  </div>`;
}

function buildContractTooltip(t) {
  const s = t.scores.contract;
  const sc = tooltipScoreColor(s.score);
  const days = daysUntil(t.contractEnd);

  const renewalScore = days === null ? 0 : days > 180 ? 100 : days > 90 ? 75 : days > 60 ? 55 : days > 30 ? 35 : days > 0 ? 15 : 0;
  const autoRenewPenalty  = t.autoRenew    ? 15 : 0;
  const noContractPenalty = !t.hasContract ? 25 : 0;

  const daysLabel = days === null ? 'No end date' : days < 0 ? 'Expired' : `${days} days`;
  const renewalBand = days === null ? 'No date → 0'
    : days > 180 ? `>180d → 100`
    : days > 90  ? `91–180d → 75`
    : days > 60  ? `61–90d → 55`
    : days > 30  ? `31–60d → 35`
    : days > 0   ? `1–30d → 15`
    : `Expired → 0`;

  return `<div class="formula-tooltip">
    <div class="ft-title">Contract Risk Formula</div>
    <div class="ft-formula">Renewal Score − Penalties</div>
    <div class="ft-inputs">
      Days to renewal = <span>${daysLabel}</span> (${renewalBand})<br>
      Auto-renew penalty = <span style="color:${t.autoRenew ? '#f87171' : '#4ade80'}">${t.autoRenew ? '−15' : '0 (no auto-renew)'}</span><br>
      No contract penalty = <span style="color:${!t.hasContract ? '#f87171' : '#4ade80'}">${!t.hasContract ? '−25' : '0 (contract on file)'}</span>
    </div>
    <div class="ft-result">${renewalScore} − ${autoRenewPenalty} − ${noContractPenalty} = <span style="color:${sc}">${s.score}</span></div>
  </div>`;
}

function buildCompletenessTooltip(t) {
  const s = t.scores.completeness;
  const sc = tooltipScoreColor(s.score);
  const hasLicense = t.licensedSeats > 0 || t.eligiblePop > 0 || t.licenseModel === 'consumption';

  const fields = [
    { label: 'Contract on file',          pts: 20, present: t.hasContract },
    { label: 'Contract start date',       pts: 15, present: !!t.contractStart },
    { label: 'Contract end date',         pts: 15, present: !!t.contractEnd },
    { label: 'Tool owner assigned',       pts: 20, present: t.hasOwner },
    { label: 'License / seat count',      pts: 15, present: hasLicense },
    { label: 'Cost center / budget owner',pts: 10, present: t.hasCostCenter },
    { label: 'Business justification',    pts:  5, present: t.hasJustification },
  ];
  const earned = fields.filter(f => f.present).reduce((a, f) => a + f.pts, 0);

  const rows = fields.map(f =>
    `<div style="display:flex;justify-content:space-between;padding:2px 0;color:${f.present ? '#4ade80' : '#f87171'}">
      <span>${f.present ? '✓' : '✗'} ${f.label}</span>
      <span style="font-weight:700;margin-left:12px">${f.present ? '+' : ''}${f.present ? f.pts : 0}/${f.pts}pts</span>
    </div>`
  ).join('');

  return `<div class="formula-tooltip" style="width:290px">
    <div class="ft-title">Data Completeness Formula</div>
    <div class="ft-formula">(Fields Present ÷ Total Points) × 100</div>
    <div class="ft-inputs" style="font-size:11px;line-height:1.8">${rows}</div>
    <div class="ft-result" style="border-top:1px solid #1e293b;padding-top:6px;margin-top:4px">
      ${earned} / 100 pts = <span style="color:${sc}">${s.score}</span>
    </div>
  </div>`;
}

// ─────────────────────────────────────────────────────────────────────────────
// MODAL
// ─────────────────────────────────────────────────────────────────────────────
function openModal(id) {
  const t = TOOLS.find(x=>x.id===id);
  if (!t) return;
  const days = daysUntil(t.contractEnd);
  const flags = [];
  if (t.composite < 40)                              flags.push({ c:"flag-red",    tx:"Critical — recommend review for consolidation or cut" });
  if (t.scores.adoption.score !== null && t.scores.adoption.score < 40) flags.push({ c:"flag-red",    tx:`Low adoption (${t.scores.adoption.score}) — potential shelfware` });
  if (t.autoRenew && days !== null && days < 90)     flags.push({ c:"flag-yellow", tx:`Auto-renew active · ${days}d to renewal — action needed` });
  if (!t.hasContract)                                flags.push({ c:"flag-red",    tx:"No contract on file — governance gap" });
  if (!t.hasOwner)                                   flags.push({ c:"flag-yellow", tx:"No tool owner assigned" });
  if (t.scores.completeness.score < 70)              flags.push({ c:"flag-yellow", tx:"Data completeness below threshold — decisions unreliable" });
  if (t.scores.adoption.score !== null && t.scores.adoption.score >= 70) flags.push({ c:"flag-green", tx:"Adoption healthy — usage defensible" });
  if (!flags.length) flags.push({ c:"flag-green", tx:"No critical issues detected" });

  const overlaps = OVERLAP_GROUPS.filter(g => g.toolIds.includes(t.id));
  const ML = { per_seat:"Per Seat / Named User", unlimited:"Unlimited / Enterprise", consumption:"Consumption / Usage-Based", flat_fee:"Flat Fee", platform:"Platform / Single-Instance", outcome_based:"Outcome-Based" };

  document.getElementById("modalTitle").textContent = t.name;
  document.getElementById("modalBody").innerHTML = `
    <div class="modal-section">
      <h3>Health Scores</h3>
      <div class="score-grid">
        <div class="score-card formula-wrap" style="border-color:${colorHex(t.adoptionGrade)};background:${colorBg(t.adoptionGrade)}">
          ${buildAdoptionTooltip(t)}
          <div class="sc-label">Adoption Rate</div>
          <div class="sc-val" style="color:${colorHex(t.adoptionGrade)}">${t.scores.adoption.score??'N/A'}</div>
          <div class="sc-desc">${t.scores.adoption.label}</div>
        </div>
        <div class="score-card formula-wrap" style="border-color:${colorHex(t.spendGrade)};background:${colorBg(t.spendGrade)}">
          ${buildSpendTooltip(t)}
          <div class="sc-label">Spend Efficiency</div>
          <div class="sc-val" style="color:${colorHex(t.spendGrade)}">${t.scores.spend.score}</div>
          <div class="sc-desc">${t.scores.spend.label}</div>
        </div>
        <div class="score-card formula-wrap" style="border-color:${colorHex(t.contractGrade)};background:${colorBg(t.contractGrade)}">
          ${buildContractTooltip(t)}
          <div class="sc-label">Contract Risk</div>
          <div class="sc-val" style="color:${colorHex(t.contractGrade)}">${t.scores.contract.score}</div>
          <div class="sc-desc">${t.scores.contract.label}</div>
        </div>
        <div class="score-card formula-wrap" style="border-color:${colorHex(t.completenessGrade)};background:${colorBg(t.completenessGrade)}">
          ${buildCompletenessTooltip(t)}
          <div class="sc-label">Data Completeness</div>
          <div class="sc-val" style="color:${colorHex(t.completenessGrade)}">${t.scores.completeness.score}</div>
          <div class="sc-desc">${t.scores.completeness.label}</div>
        </div>
      </div>
    </div>
    <div class="modal-section">
      <h3>Tool Details</h3>
      <div class="kpi-legend">
        <span style="font-size:11px;color:var(--text-muted);font-weight:600;margin-right:4px">Field used by:</span>
        <div class="kpi-legend-item"><span class="kpi-tag kt-adoption">Adoption</span></div>
        <div class="kpi-legend-item"><span class="kpi-tag kt-spend">Spend Eff.</span></div>
        <div class="kpi-legend-item"><span class="kpi-tag kt-contract">Contract Risk</span></div>
        <div class="kpi-legend-item"><span class="kpi-tag kt-completeness">Data Compl.</span></div>
      </div>
      <div class="kv-row"><span class="kv-key">Category</span><span class="kv-val">${t.category}</span></div>
      <div class="kv-row"><span class="kv-key">Portfolio Owner</span><span class="kv-val">${t.owner}</span></div>
      <div class="kv-row"><span class="kv-key">License Model</span><span class="kv-val">${ML[t.licenseModel]||t.licenseModel}</span></div>
      <div class="kv-row">
        <span class="kv-key">Annual Contract Value<span class="kpi-tag kt-spend">Spend Eff.</span></span>
        <span class="kv-val">${fmt$(t.annualCost)}</span>
      </div>
      <div class="kv-row">
        <span class="kv-key">Contract Start<span class="kpi-tag kt-completeness">Data Compl. +15pts</span></span>
        <span class="kv-val">${t.contractStart||"—"}</span>
      </div>
      <div class="kv-row">
        <span class="kv-key">Contract End<span class="kpi-tag kt-completeness">Data Compl. +15pts</span><span class="kpi-tag kt-contract">Contract Risk</span></span>
        <span class="kv-val">${t.contractEnd||"—"} ${days!==null?`(${days>0?days+"d":"expired"})`:"" }</span>
      </div>
      <div class="kv-row">
        <span class="kv-key">Auto-Renew<span class="kpi-tag kt-contract">Contract Risk −15pts</span></span>
        <span class="kv-val" style="color:${t.autoRenew?"var(--red)":"var(--green)"}">${t.autoRenew?"Yes — Risk":"No"}</span>
      </div>
      <div class="kv-row">
        <span class="kv-key">Contract on File<span class="kpi-tag kt-completeness">Data Compl. +20pts</span><span class="kpi-tag kt-contract">Contract Risk −25pts if missing</span></span>
        <span class="kv-val" style="color:${t.hasContract?"var(--green)":"var(--red)"}">${t.hasContract?"Yes":"No"}</span>
      </div>
      <div class="kv-row">
        <span class="kv-key">Owner Assigned<span class="kpi-tag kt-completeness">Data Compl. +20pts</span></span>
        <span class="kv-val" style="color:${t.hasOwner?"var(--green)":"var(--red)"}">${t.hasOwner?"Yes":"No"}</span>
      </div>
      <div class="kv-row">
        <span class="kv-key">Cost Center<span class="kpi-tag kt-completeness">Data Compl. +10pts</span></span>
        <span class="kv-val" style="color:${t.hasCostCenter?"var(--green)":"var(--yellow)"}">${t.hasCostCenter?"Yes":"Missing"}</span>
      </div>
      <div class="kv-row">
        <span class="kv-key">Business Justification<span class="kpi-tag kt-completeness">Data Compl. +5pts</span></span>
        <span class="kv-val" style="color:${t.hasJustification?"var(--green)":"var(--yellow)"}">${t.hasJustification?"Yes":"Missing"}</span>
      </div>
      ${t.activeUsers?`<div class="kv-row">
        <span class="kv-key">Active Users (30d)<span class="kpi-tag kt-adoption">Adoption</span><span class="kpi-tag kt-spend">Spend Eff.</span></span>
        <span class="kv-val">${t.activeUsers.toLocaleString()}</span>
      </div>`:""}
      ${t.licensedSeats?`<div class="kv-row">
        <span class="kv-key">Licensed Seats<span class="kpi-tag kt-adoption">Adoption</span><span class="kpi-tag kt-spend">Spend Eff.</span><span class="kpi-tag kt-completeness">Data Compl. +15pts</span></span>
        <span class="kv-val">${t.licensedSeats.toLocaleString()}</span>
      </div>`:""}
      ${t.eligiblePop?`<div class="kv-row">
        <span class="kv-key">Eligible Population<span class="kpi-tag kt-adoption">Adoption</span><span class="kpi-tag kt-spend">Spend Eff.</span><span class="kpi-tag kt-completeness">Data Compl. +15pts</span></span>
        <span class="kv-val">${t.eligiblePop.toLocaleString()}</span>
      </div>`:""}
    </div>
    ${overlaps.length ? `
    <div class="modal-section">
      <h3>Capability Overlaps</h3>
      ${overlaps.map(g=>`
        <div style="padding:10px 12px;border-radius:8px;background:var(--yellow-bg);border:1px solid var(--yellow-border);margin-bottom:8px;font-size:12px">
          <strong>${g.category}</strong> — ${g.note}
        </div>
      `).join("")}
    </div>` : ""}
    <div class="modal-section">
      <h3>Flags & Recommendations</h3>
      <div class="flag-list">${flags.map(f=>`<div class="flag ${f.c}">${f.tx}</div>`).join("")}</div>
    </div>
  `;
  document.getElementById("modal").classList.add("open");
}

function closeModal() { document.getElementById("modal").classList.remove("open"); }
function closeModalOnBackdrop(e) { if (e.target.id==="modal") closeModal(); }

// ─────────────────────────────────────────────────────────────────────────────
// EXPORT
// ─────────────────────────────────────────────────────────────────────────────
function exportCSV() {
  const cols = ["Tool","Category","Portfolio Owner","License Model","Adoption","Spend Efficiency","Contract Risk","Data Completeness","Health Score","Status","Annual Cost","Contract End","Auto-Renew"];
  const rows = filteredTools.map(t => [
    t.name, t.category, t.owner, t.licenseModel,
    t.scores.adoption.score ?? "", t.scores.spend.score, t.scores.contract.score, t.scores.completeness.score,
    t.composite, t.health, t.annualCost, t.contractEnd||"", t.autoRenew?"Yes":"No"
  ]);
  const csv = [cols,...rows].map(r=>r.map(v=>`"${v}"`).join(",")).join("\n");
  const a = document.createElement("a");
  a.href = "data:text/csv," + encodeURIComponent(csv);
  a.download = "etg-portfolio-health.csv";
  a.click();
}

